#!/bin/bash
# Zellij tab renaming hook for Claude Code
# Uses rename-tab --tab-id (Zellij 0.44+) to rename without switching tabs

# Skip early if not in Zellij
[ -z "$ZELLIJ_SESSION_NAME" ] && exit 0
[ -z "$ZELLIJ_PANE_ID" ] && exit 0

# Read JSON from stdin
input=$(cat)
[ -z "$input" ] && exit 0

hook_event=$(echo "$input" | jq -r '.hook_event_name // ""' 2>/dev/null)
[ -z "$hook_event" ] && exit 0

session_id=$(echo "$input" | jq -r '.session_id // ""' 2>/dev/null)
TAB_ID_FILE="/tmp/zellij-claude-tabid-${session_id}"

# On SessionStart, discover and cache our tab_id
if [ "$hook_event" = "SessionStart" ]; then
    tab_id=$(zellij action list-panes --json --tab 2>/dev/null \
        | jq -r --argjson pid "$ZELLIJ_PANE_ID" '.[] | select(.id == $pid) | .tab_id')
    if [ -n "$tab_id" ]; then
        echo "$tab_id" > "$TAB_ID_FILE"
    fi
fi

# Read cached tab_id
tab_id=""
[ -f "$TAB_ID_FILE" ] && tab_id=$(cat "$TAB_ID_FILE")

# Generate tab name
tool_name=$(echo "$input" | jq -r '.tool_name // ""' 2>/dev/null)
tool_input=$(echo "$input" | jq -c '.tool_input // {}' 2>/dev/null)
notification_type=$(echo "$input" | jq -r '.notification_type // ""' 2>/dev/null)

if [ "$notification_type" = "idle_prompt" ]; then
    hook_event="Notification"
fi

case "$hook_event" in
    SessionStart)       tab_name="🚀" ;;
    SessionEnd)         tab_name="👋"; rm -f "$TAB_ID_FILE" ;;
    UserPromptSubmit)   tab_name="⚡" ;;
    Stop)               tab_name="😴" ;;
    Notification)       tab_name="😴" ;;
    PostToolUse)        tab_name="⚡" ;;
    PreToolUse)
        case "$tool_name" in
            Bash)
                cmd=$(echo "$tool_input" | jq -r '.command // ""' 2>/dev/null)
                [ ${#cmd} -gt 30 ] && cmd="${cmd:0:27}..."
                tab_name="⚙️ $cmd"
                ;;
            Write|Edit)
                path=$(echo "$tool_input" | jq -r '.file_path // ""' 2>/dev/null)
                tab_name="✏️ $(basename "$path" 2>/dev/null)"
                ;;
            Read)
                path=$(echo "$tool_input" | jq -r '.file_path // ""' 2>/dev/null)
                tab_name="📖 $(basename "$path" 2>/dev/null)"
                ;;
            Glob|Grep)
                pattern=$(echo "$tool_input" | jq -r '.pattern // ""' 2>/dev/null)
                [ ${#pattern} -gt 25 ] && pattern="${pattern:0:22}..."
                tab_name="🔍 $pattern"
                ;;
            Agent)      tab_name="🤖" ;;
            *)          tab_name="⚙️" ;;
        esac
        ;;
    *)                  tab_name="⚙️" ;;
esac

# Rename the tab
if [ -n "$tab_id" ]; then
    zellij action rename-tab "$tab_name" --tab-id "$tab_id" 2>/dev/null
else
    # Fallback: rename current tab (only correct if Claude tab is focused)
    zellij action rename-tab "$tab_name" 2>/dev/null
fi

exit 0
