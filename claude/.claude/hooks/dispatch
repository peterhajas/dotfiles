#!/bin/bash
# Thin dispatcher — reads stdin once, fans out to all hooks in parallel
input=$(cat)
HOOK_DIR="$(dirname "$0")"

echo "$input" | "$HOOK_DIR/hammerspoon_hook" >/dev/null 2>&1 &
echo "$input" | "$HOOK_DIR/zellij_rename" >/dev/null 2>&1 &
echo "$input" | "$HOOK_DIR/zellij_pane_color" >/dev/null 2>&1 &
echo "$input" | "$HOOK_DIR/ntfy_hook" >/dev/null 2>&1 &
wait
