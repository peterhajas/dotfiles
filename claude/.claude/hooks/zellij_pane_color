#!/bin/bash
# Zellij pane color hook for Claude Code
# Sets pane background to red when idle, resets when processing

# Skip if not in Zellij
[ -z "$ZELLIJ_SESSION_NAME" ] && exit 0
[ -z "$ZELLIJ_PANE_ID" ] && exit 0

PANE_TARGET="terminal_${ZELLIJ_PANE_ID}"

# Detect dark/light mode
get_idle_color() {
    local appearance
    appearance=$(defaults read -g AppleInterfaceStyle 2>/dev/null)
    if [ "$appearance" = "Dark" ]; then
        echo "#3a0000"
    else
        echo "#ffe0e0"
    fi
}

set_idle_color() {
    local bg
    bg=$(get_idle_color)
    zellij action set-pane-color --pane-id "$PANE_TARGET" --bg "$bg" >/dev/null 2>&1
}

reset_color() {
    zellij action set-pane-color --pane-id "$PANE_TARGET" --reset >/dev/null 2>&1
}

# Read event from stdin
input=$(cat)
hook_event=$(echo "$input" | jq -r '.hook_event_name // ""' 2>/dev/null)
notification_type=$(echo "$input" | jq -r '.notification_type // ""' 2>/dev/null)

if [ "$notification_type" = "idle_prompt" ]; then
    hook_event="Notification"
fi

case "$hook_event" in
    Stop|Notification)
        set_idle_color
        ;;
    PostToolUse)
        tool_name=$(echo "$input" | jq -r '.tool_name // ""' 2>/dev/null)
        case "$tool_name" in
            ExitPlanMode|AskUserQuestion)
                set_idle_color
                ;;
        esac
        ;;
    UserPromptSubmit|PreToolUse|SessionStart|SessionEnd)
        reset_color
        ;;
esac
