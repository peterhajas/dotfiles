#!/bin/bash
# Zellij pane color hook for Claude Code
# Sets pane background to red when idle, resets when processing

# Skip if not in Zellij
[ -z "$ZELLIJ_SESSION_NAME" ] && exit 0
[ -z "$ZELLIJ_PANE_ID" ] && exit 0

PANE_TARGET="terminal_${ZELLIJ_PANE_ID}"

# Detect dark/light mode
get_idle_color() {
    local appearance
    appearance=$(defaults read -g AppleInterfaceStyle 2>/dev/null)
    if [ "$appearance" = "Dark" ]; then
        echo "#3a0000"
    else
        echo "#ffe0e0"
    fi
}

set_idle_color() {
    local bg
    bg=$(get_idle_color)
    zellij action set-pane-color --pane-id "$PANE_TARGET" --bg "$bg" >/dev/null 2>&1
}

reset_color() {
    zellij action set-pane-color --pane-id "$PANE_TARGET" --reset >/dev/null 2>&1
}

# Check if a tool call matches any "ask" permission pattern in settings.json
matches_ask_pattern() {
    local tool_name="$1"
    local input="$2"
    local settings="$HOME/.claude/settings.json"
    [ -f "$settings" ] || return 1

    local command=""
    if [ "$tool_name" = "Bash" ]; then
        command=$(echo "$input" | jq -r '.tool_input.command // ""' 2>/dev/null)
    fi

    while IFS= read -r pattern; do
        if [[ "$pattern" == Bash\(* ]]; then
            [ "$tool_name" != "Bash" ] && continue
            local inner="${pattern#Bash(}"
            inner="${inner%)}"
            inner="${inner%:\*}"
            inner="${inner%\*}"
            # Handle wildcard prefix like */tw
            if [[ "$inner" == \*/* ]]; then
                local suffix="${inner#\*/}"
                [[ "$command" =~ (^|.*/)"$suffix"($|[[:space:]]) ]] && return 0
            else
                [[ "$command" == "$inner"* ]] && return 0
            fi
        else
            [ "$tool_name" = "$pattern" ] && return 0
        fi
    done < <(jq -r '.permissions.ask[]? // empty' "$settings" 2>/dev/null)

    return 1
}

# Read event from stdin
input=$(cat)
hook_event=$(echo "$input" | jq -r '.hook_event_name // ""' 2>/dev/null)
notification_type=$(echo "$input" | jq -r '.notification_type // ""' 2>/dev/null)

if [ "$notification_type" = "idle_prompt" ]; then
    hook_event="Notification"
fi

case "$hook_event" in
    Stop|Notification)
        set_idle_color
        ;;
    PreToolUse)
        tool_name=$(echo "$input" | jq -r '.tool_name // ""' 2>/dev/null)
        case "$tool_name" in
            ExitPlanMode|AskUserQuestion)
                set_idle_color
                ;;
            *)
                if matches_ask_pattern "$tool_name" "$input"; then
                    set_idle_color
                else
                    reset_color
                fi
                ;;
        esac
        ;;
    PostToolUse)
        reset_color
        ;;
    UserPromptSubmit|SessionStart|SessionEnd)
        reset_color
        ;;
esac

exit 0
