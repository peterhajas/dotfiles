#!/bin/sh

# Directories to search (edit these as needed)
SEARCH_DIRS="
$HOME
$HOME/src
"

# Bookmarked sessions: name|path
BOOKMARKS="
phajas-wiki|$HOME/phajas-wiki
scratch|$HOME/scratch
kanata|$HOME/.config/kanata
sysmon|$HOME
"

# Function to kill any existing "zellij attach SESSION_NAME" processes
kill_existing_attach_processes() {
    session_name="$1"
    # Kill any zellij clients already attached to this session (tmux-style "attach -d").
    # Match common argv forms like "zellij attach NAME" or "zellij a NAME".
    pids=$(pgrep -f "zellij (attach|a) $session_name" 2>/dev/null || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 2>/dev/null || true
    fi
}

# --pick-dir: skip all session manipulation, just print the chosen directory.
# Used by `cdg` (fish ctrl-g) to navigate without creating/switching sessions.
PICK_DIR_ONLY=0
case "${1:-}" in
    --pick-dir|-p) PICK_DIR_ONLY=1 ;;
esac

INSIDE_ZELLIJ="${ZELLIJ:-}"
CURRENT_SESSION="${ZELLIJ_SESSION_NAME:-}"

# Zellij creates a unix-domain socket at $TMPDIR/zellij-<uid>/contract_version_1/<session>.
# On macOS sockaddr_un.sun_path is 104 bytes — overflowing it makes the
# server panic on bind and the client hang forever (no error surfaced).
# Compute a safe upper bound and truncate session names that would overflow.
ZELLIJ_SOCKET_DIR="${TMPDIR:-/tmp}/zellij-$(id -u 2>/dev/null)/contract_version_1"
MAX_SESSION_NAME_LEN=$(( 100 - ${#ZELLIJ_SOCKET_DIR} - 1 ))
[ "$MAX_SESSION_NAME_LEN" -lt 8 ] && MAX_SESSION_NAME_LEN=8

truncate_session_name() {
    name="$1"
    if [ "${#name}" -gt "$MAX_SESSION_NAME_LEN" ]; then
        printf '%s' "$name" | cut -c1-"$MAX_SESSION_NAME_LEN"
    else
        printf '%s' "$name"
    fi
}

# Prevent multiple overlapping sessionize pickers (use a lockfile instead of
# slow IPC via list-panes). Only relevant when triggered via the zellij Run
# keybind, not when invoked synchronously by fish (e.g. cdg).
LOCKFILE="${TMPDIR:-/tmp}/sessionize.lock"
if [ -n "$INSIDE_ZELLIJ" ] && [ "$PICK_DIR_ONLY" = 0 ]; then
    if ! mkdir "$LOCKFILE" 2>/dev/null; then
        exit 0
    fi
    trap 'rmdir "$LOCKFILE" 2>/dev/null' EXIT INT TERM
fi

# Function to get the appropriate layout for a session
get_layout() {
    session_name="$1"
    layout_dir="$HOME/.config/zellij/layouts"

    # First try session-specific layout
    if [ -f "$layout_dir/$session_name.kdl" ]; then
        echo "$session_name"
    else
        # Fall back to zellij's built-in default layout
        echo "default"
    fi
}

set_terminal_title() {
    session_name="$1"
    [ -n "$session_name" ] && printf '\033]0;zellij: %s\a' "$session_name"
}

resolve_dir() {
    dir="$1"
    if [ -n "$dir" ] && [ -d "$dir" ]; then
        (cd "$dir" && pwd)
    else
        pwd
    fi
}

start_new_session() {
    session_name="$1"
    layout="$2"
    session_cwd=$(resolve_dir "$3")

    set_terminal_title "$session_name"

    # `attach -c` creates the session if missing and attaches; the `options`
    # subcommand sets a default cwd so new tabs open in the same workspace.
    (cd "$session_cwd" && zellij attach -c "$session_name" options --default-cwd "$session_cwd" --default-layout "$layout")
}

# Get existing zellij sessions with visual indicator.
# Read the socket dir directly — `zellij list-sessions` is slow (700ms–3s+
# when there are EXITED sessions to validate). EXITED sessions that have no
# live socket won't show up; typing their name + Ctrl+N still resurrects via
# `zellij attach -c`.
if [ -d "$ZELLIJ_SOCKET_DIR" ]; then
    ACTIVE_SESSION_NAMES=$(ls -1 "$ZELLIJ_SOCKET_DIR" 2>/dev/null)
else
    ACTIVE_SESSION_NAMES=""
fi
SESSIONS=""
CURRENT_SESSION_LINE=""
# In --pick-dir mode, skip session entries — they don't map to a directory.
if [ -n "$ACTIVE_SESSION_NAMES" ] && [ "$PICK_DIR_ONLY" = 0 ]; then
    while IFS= read -r session; do
        [ -n "$session" ] || continue
        if [ "$session" = "$CURRENT_SESSION" ]; then
            CURRENT_SESSION_LINE="${session} [current session]"
        else
            SESSIONS="${SESSIONS}${session} [active session]
"
        fi
    done <<EOF
$ACTIVE_SESSION_NAMES
EOF
fi

session_exists() {
    target="$1"
    while IFS= read -r active; do
        [ -n "$active" ] || continue
        [ "$active" = "$target" ] && return 0
    done <<EOF
$ACTIVE_SESSION_NAMES
EOF
    return 1
}

# Build bookmark options with a stable label for fzf.
BOOKMARK_OPTIONS=""
IFS='
'
for line in $BOOKMARKS; do
    [ -n "$line" ] || continue
    name=$(printf "%s" "$line" | cut -d'|' -f1)
    dir=$(printf "%s" "$line" | cut -d'|' -f2-)
    [ -n "$name" ] || continue
    # If a session is already active, the active session entry is enough.
    if session_exists "$name"; then
        continue
    fi
    if [ -n "$dir" ] && [ -d "$dir" ]; then
        dir=$(resolve_dir "$dir")
    fi
    BOOKMARK_OPTIONS="${BOOKMARK_OPTIONS}${name} :: ${dir} [bookmark]
"
done
unset IFS

# Find directories at depth 1 in each search directory.
# Use shell globbing to avoid spawning find for every run.
DIRS=""
for search_dir in $SEARCH_DIRS; do
    if [ -d "$search_dir" ]; then
        for dir in "$search_dir"/*; do
            [ -d "$dir" ] || continue
            DIRS="${DIRS}${dir}
"
        done
    fi
done

# Combine sessions (first) and directories. Current session last.
ALL_OPTIONS="$SESSIONS
$BOOKMARK_OPTIONS
$DIRS
$CURRENT_SESSION_LINE"

SCRIPT_PATH="$0"
case "$SCRIPT_PATH" in
    */*) ;;
    *)
        # When invoked via $PATH, $0 may be just "sessionize". Resolve to an
        # actual path so we can reliably find the preview helper next to it.
        SCRIPT_PATH=$(command -v -- "$SCRIPT_PATH" 2>/dev/null || printf "%s" "$SCRIPT_PATH")
        ;;
esac
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
PREVIEW_HELPER="$SCRIPT_DIR/.zellij_sessionize_preview"
PREVIEW_CMD="sh $PREVIEW_HELPER {}"
FZF_PROMPT="Session: "
[ "$PICK_DIR_ONLY" = 1 ] && FZF_PROMPT="Cd: "
RESULT=$(printf "%s\n" "$ALL_OPTIONS" | grep -v '^$' | fzf --prompt="$FZF_PROMPT" --print-query --expect=ctrl-n --preview="$PREVIEW_CMD" --preview-window=right:70%:wrap --bind=ctrl-/:toggle-preview --ansi)

if [ -z "$RESULT" ]; then
    exit 0
fi

# fzf outputs: key pressed, query, selection
KEY=""
QUERY=""
SELECTION=""
{
    IFS= read -r KEY
    IFS= read -r QUERY
    IFS= read -r SELECTION
} <<EOF
$RESULT
EOF

# In --pick-dir mode, resolve the selection to a directory and print it.
# Bookmarks have a path baked in; bare entries are directory paths; query +
# Ctrl+N has no directory (silent no-op).
if [ "$PICK_DIR_ONLY" = 1 ]; then
    [ "$KEY" = "ctrl-n" ] && exit 0
    [ -z "$SELECTION" ] && exit 0
    case "$SELECTION" in
    *" [bookmark]")
        SELECTION_NO_TAG=${SELECTION% \[bookmark\]}
        BOOKMARK_DIR=${SELECTION_NO_TAG#* :: }
        if [ -n "$BOOKMARK_DIR" ] && [ -d "$BOOKMARK_DIR" ]; then
            printf '%s\n' "$BOOKMARK_DIR"
        fi
        ;;
    *)
        if [ -d "$SELECTION" ]; then
            printf '%s\n' "$SELECTION"
        fi
        ;;
    esac
    exit 0
fi

# If Ctrl+N was pressed or no selection was made, create new session with query name
if [ "$KEY" = "ctrl-n" ] || [ -z "$SELECTION" ]; then
    SESSION_NAME="$QUERY"
    if [ -z "$SESSION_NAME" ]; then
        exit 0
    fi
    SESSION_NAME=$(truncate_session_name "$SESSION_NAME")
    LAYOUT=$(get_layout "$SESSION_NAME")
    SESSION_CWD=$(pwd)

    # Check if session already exists
    if session_exists "$SESSION_NAME"; then
        if [ -n "$INSIDE_ZELLIJ" ]; then
            zellij action switch-session "$SESSION_NAME"
        else
            kill_existing_attach_processes "$SESSION_NAME"
            set_terminal_title "$SESSION_NAME"
            zellij attach "$SESSION_NAME"
        fi
    else
        if [ -n "$INSIDE_ZELLIJ" ]; then
            zellij action switch-session "$SESSION_NAME" --layout "$LAYOUT" --cwd "$SESSION_CWD"
        else
            start_new_session "$SESSION_NAME" "$LAYOUT" "$SESSION_CWD"
        fi
    fi
    exit 0
fi

# Handle existing session selection
case "$SELECTION" in
*" [active session]"|*" [current session]")
    SESSION_NAME=${SELECTION% \[active session\]}
    SESSION_NAME=${SESSION_NAME% \[current session\]}
    if [ -n "$INSIDE_ZELLIJ" ]; then
        zellij action switch-session "$SESSION_NAME"
    else
        kill_existing_attach_processes "$SESSION_NAME"
        set_terminal_title "$SESSION_NAME"
        zellij attach "$SESSION_NAME"
    fi
    exit 0
    ;;
esac

# Handle bookmark selection
case "$SELECTION" in
*" [bookmark]")
    SELECTION_NO_TAG=${SELECTION% \[bookmark\]}
    SESSION_NAME=${SELECTION_NO_TAG%% :: *}
    BOOKMARK_DIR=${SELECTION_NO_TAG#* :: }

    if [ -z "$SESSION_NAME" ]; then
        exit 0
    fi
    SESSION_NAME=$(truncate_session_name "$SESSION_NAME")

    if [ -z "$BOOKMARK_DIR" ] || [ ! -d "$BOOKMARK_DIR" ]; then
        BOOKMARK_DIR="$HOME"
    fi

    if session_exists "$SESSION_NAME"; then
        if [ -n "$INSIDE_ZELLIJ" ]; then
            zellij action switch-session "$SESSION_NAME"
        else
            kill_existing_attach_processes "$SESSION_NAME"
            set_terminal_title "$SESSION_NAME"
            zellij attach "$SESSION_NAME"
        fi
    else
        LAYOUT=$(get_layout "$SESSION_NAME")
        if [ -n "$INSIDE_ZELLIJ" ]; then
            zellij action switch-session "$SESSION_NAME" --layout "$LAYOUT" --cwd "$BOOKMARK_DIR"
        else
            start_new_session "$SESSION_NAME" "$LAYOUT" "$BOOKMARK_DIR"
        fi
    fi
    exit 0
    ;;
esac

# Handle directory choice
DIR="$SELECTION"
SESSION_NAME=${DIR##*/}
SESSION_NAME=$(truncate_session_name "$SESSION_NAME")

# Check if session exists
if session_exists "$SESSION_NAME"; then
    if [ -n "$INSIDE_ZELLIJ" ]; then
        zellij action switch-session "$SESSION_NAME"
    else
        kill_existing_attach_processes "$SESSION_NAME"
        set_terminal_title "$SESSION_NAME"
        zellij attach "$SESSION_NAME"
    fi
else
    LAYOUT=$(get_layout "$SESSION_NAME")
    if [ -n "$INSIDE_ZELLIJ" ]; then
        zellij action switch-session "$SESSION_NAME" --layout "$LAYOUT" --cwd "$DIR"
    else
        start_new_session "$SESSION_NAME" "$LAYOUT" "$DIR"
    fi
fi
