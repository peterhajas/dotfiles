#!/usr/bin/env bash
# Advance Zellij's swap layout after normalizing panes to visible order.

set -euo pipefail

tab_id=$(zellij action current-tab-info --json | jq -r '.tab_id')

mapfile -t pane_ids < <(
    zellij action list-panes --json --all |
        jq -r --argjson tab_id "$tab_id" '
            [
                .[]
                | select(.tab_id == $tab_id)
                | select(.is_plugin == false)
                | select(.is_floating == false)
                | select((.exited // false) == false)
                | select((.is_suppressed // false) == false)
                | {
                    id: ("terminal_" + (.id | tostring)),
                    y: (.pane_y // 0),
                    x: (.pane_x // 0)
                }
            ]
            | sort_by(.y, .x)
            | .[].id
        '
)

if (( ${#pane_ids[@]} <= 1 )); then
    exit 0
fi

zellij action stack-panes -- "${pane_ids[@]}"
zellij action next-swap-layout --tab-id "$tab_id"
