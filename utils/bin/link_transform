#!/usr/bin/env python3
"""Cleans up URLs for sharing.

Usage: printf %s "https://twitter.com/..." | link_transform
Requires Python 3 via /usr/bin/env in the shebang.
"""

import re
import sys


FARSIDE_DOMAINS = (
    "imgur.com",
    "instagram.com",
    "medium.com",
    "tiktok.com",
)

STRIP_PARAMS = {
    "dclid",
    "fbclid",
    "feature",
    "gclid",
    "igshid",
    "mc_cid",
    "mc_eid",
    "pp",
    "ref",
    "ref_src",
    "si",
    "spm",
    "utm_campaign",
    "utm_content",
    "utm_medium",
    "utm_source",
    "utm_term",
}

BASE_REWRITES = (
    (re.compile(r"^https?://(?:www\.)?x\.com(?=/|$)"), "https://x.peterhajas.com"),
    (re.compile(r"^https?://(?:www\.)?twitter\.com(?=/|$)"), "https://x.peterhajas.com"),
    (re.compile(r"^https?://mobile\.twitter\.com(?=/|$)"), "https://x.peterhajas.com"),
    (re.compile(r"^https?://(?:www\.)?reddit\.com(?=/|$)"), "https://reddit.peterhajas.com"),
    (re.compile(r"^https?://old\.reddit\.com(?=/|$)"), "https://reddit.peterhajas.com"),
)


def rewrite_base(base: str) -> str:
    for pattern, replacement in BASE_REWRITES:
        if pattern.search(base):
            return pattern.sub(replacement, base, count=1)
    return base


def clean_query(query: str) -> str:
    if not query:
        return ""

    cleaned_parts = []
    for param in query.split("&"):
        key = param.split("=", 1)[0]
        if key.startswith("utm_") or key in STRIP_PARAMS:
            continue
        cleaned_parts.append(param)

    return "&".join(cleaned_parts)


def maybe_wrap_farside(url: str) -> str:
    for domain in FARSIDE_DOMAINS:
        https_prefix = f"https://{domain}"
        www_prefix = f"https://www.{domain}"
        if url.startswith(https_prefix) or url.startswith(www_prefix):
            return f"https://farside.link/{url}"
    return url


def transform(contents: str) -> str:
    if not contents or not re.match(r"^https?://", contents):
        return ""

    base_with_query, fragment_separator, fragment = contents.partition("#")
    base, query_separator, query = base_with_query.partition("?")

    clean = rewrite_base(base)

    if query_separator:
        cleaned_query = clean_query(query)
        if cleaned_query:
            clean = f"{clean}?{cleaned_query}"

    if fragment_separator:
        clean = f"{clean}#{fragment}"

    clean = maybe_wrap_farside(clean)

    if clean == contents:
        return ""

    return clean


def main() -> int:
    contents = sys.stdin.read()
    output = transform(contents)
    if output:
        sys.stdout.write(output)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
